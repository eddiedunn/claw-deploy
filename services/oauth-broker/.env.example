# OAuth Broker Service — Deployment Configuration
# Copy to .env and customize for your deployment target

# --- Target Host ---
CLAW_HOST=your-server
CLAW_SSH_USER=your-ssh-user

# --- Service User ---
CLAW_USER=oauthbroker
CLAW_UID=989
CLAW_GID=989
CLAW_HOME=/data/oauth-broker

# --- Subuid/Subgid (must not overlap with other service users on this host) ---
# Existing allocations: openclaw 231072–296607, tradeclaw 296608–362143
CLAW_SUBUID_START=362144
CLAW_SUBUID_COUNT=65536

# --- Source + Image ---
# Set CLAW_REPO_URL to the oauth-service git remote
CLAW_REPO_URL=https://github.com/eddiedunn/oauth-broker.git
CLAW_REPO_BRANCH=main
CLAW_IMAGE=oauth-broker:local

# --- Service ---
CLAW_PORT=8420
CLAW_MEMORY=2g
CLAW_CPUS=2
CLAW_DNS_PRIMARY=100.100.100.100
CLAW_DNS_FALLBACK=1.1.1.1

# --- App Runtime Config (passed to the broker container) ---
# OB_ENCRYPTION_KEY is stored as a podman secret — never set it here
OB_LOG_LEVEL=info
OB_CALLBACK_BASE_URL=http://localhost:8420
OB_REFRESH_MARGIN_SECONDS=300
OB_SCHEDULER_INTERVAL_SECONDS=60
