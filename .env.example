# =============================================================================
# Claw Deploy Configuration
# =============================================================================
# Copy this file to .env and customize for your environment:
#   cp .env.example .env
#
# All scripts source this file automatically.
#
# Multi-host: Create per-host files (e.g. .env.trinity, .env.tela) and
# copy the target one as .env before deploying:
#   cp .env.trinity .env
# =============================================================================

# --- Variant ---
# Which claw variant to deploy: openclaw, picoclaw, gclaw, or tradeclaw
CLAW_VARIANT=openclaw

# --- Branch ---
# Git branch to clone/checkout (empty = default branch, gclaw defaults to eddie/deploy)
CLAW_REPO_BRANCH=

# --- Host ---
# Hostname of the server where Claw is deployed
CLAW_HOST=your-server
# SSH username for connecting to the host
CLAW_SSH_USER=sshuser

# --- DNS ---
# Primary DNS server
CLAW_DNS_PRIMARY=100.100.100.100
# Fallback DNS server
CLAW_DNS_FALLBACK=1.1.1.1

# --- Service User ---
# System username for running the claw variant
CLAW_USER=openclaw
# UID for the service user
CLAW_UID=993
# GID for the service user
CLAW_GID=990
# Home directory for the service user
CLAW_HOME=/data/openclaw

# --- Subuid/Subgid ---
# Starting subordinate UID for rootless Podman (must not overlap with other users)
CLAW_SUBUID_START=231072
# Number of subordinate UIDs to allocate
CLAW_SUBUID_COUNT=65536

# --- Ports ---
# Gateway port (control UI + WebSocket) — defaults derived from variant if empty
CLAW_GATEWAY_PORT=
# Bridge port — defaults derived from variant if empty
CLAW_BRIDGE_PORT=

# --- Container ---
# Container image name (empty = derived from variant, e.g. openclaw:local)
CLAW_IMAGE=

# --- Resource Limits (default/primary instance) ---
# Memory limit for the default instance
CLAW_MEMORY_DEFAULT=8g
# CPU limit for the default instance
CLAW_CPUS_DEFAULT=4

# --- Resource Limits (additional instances) ---
# Memory limit for additional instances
CLAW_MEMORY_INSTANCE=4g
# CPU limit for additional instances
CLAW_CPUS_INSTANCE=2

# --- GDEX Trading (gclaw only) ---
# Shared public GDEX API key (pre-filled, no changes needed)
GDEX_API_KEY=3f6c9e12-7b41-4c2a-9d5e-1a8f3b7e6c90,8d2a5f47-2e13-4b9c-a6f1-0c9e7d3a5b21
# EVM custodial wallet address used for GDEX trading (REQUIRED for gclaw)
WALLET_ADDRESS=
# EVM private key for the custodial wallet (REQUIRED for gclaw — keep secret)
PRIVATE_KEY=

# --- Base Chain Trading (tradeclaw only) ---
# EVM private key (REQUIRED for tradeclaw swaps)
# PRIVATE_KEY=0x...
# 0x API key for swap routing (optional, improves quote quality)
# ZEROX_API_KEY=
# Base RPC URL (defaults to https://mainnet.base.org)
# BASE_RPC_URL=https://mainnet.base.org

# --- Fork Mode (local development only — NEVER enable in production) ---
# Forks Base mainnet locally via Anvil for safe testing without real funds.
# Start Anvil first: anvil --fork-url $BASE_RPC_URL --chain-id 8453
# TRADECLAW_FORK_MODE=true
# TRADECLAW_FORK_RPC_URL=http://127.0.0.1:8545
