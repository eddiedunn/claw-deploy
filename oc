#!/usr/bin/env bash
# oc — OpenClaw instance CLI wrapper
#
# Usage:
#   oc <instance> <command...>        Run an openclaw command on an instance
#   oc <instance> --shell             Drop into a shell inside the container
#   oc <instance> --logs [N]          Tail container logs (default 50)
#   oc list                           List all instances
#   oc help                           Show this help
#
# Examples:
#   oc default devices list
#   oc default devices approve --latest
#   oc default config set gateway.bind loopback
#   oc research configure
#   oc default --shell
#   oc default --logs 100
#
# Works from anywhere — detects if running on the host or remotely.

set -euo pipefail

# --- Load config ---
# Resolve through symlinks to find the real script location
SCRIPT_SOURCE="${BASH_SOURCE[0]}"
while [[ -L "$SCRIPT_SOURCE" ]]; do
    SCRIPT_DIR="$(cd "$(dirname "$SCRIPT_SOURCE")" && pwd)"
    SCRIPT_SOURCE="$(readlink "$SCRIPT_SOURCE")"
    [[ "$SCRIPT_SOURCE" != /* ]] && SCRIPT_SOURCE="$SCRIPT_DIR/$SCRIPT_SOURCE"
done
SCRIPT_DIR="$(cd "$(dirname "$SCRIPT_SOURCE")" && pwd)"
ENV_FILE="${SCRIPT_DIR}/.env"

if [[ -f "$ENV_FILE" ]]; then
    # shellcheck disable=SC1090
    source "$ENV_FILE"
fi

OC_HOST="${OPENCLAW_HOST:-}"
OC_USER="${OPENCLAW_USER:-openclaw}"
OC_UID="${OPENCLAW_UID:-993}"
OC_HOME="${OPENCLAW_HOME:-/data/openclaw}"

# --- Helpers ---
usage() {
    sed -n '2,/^$/s/^# \?//p' "$0"
    exit 0
}

die() { echo "error: $*" >&2; exit 1; }

is_local() {
    [[ -z "$OC_HOST" ]] && return 0
    local this_host
    this_host="$(hostname -s 2>/dev/null || hostname)"
    [[ "$this_host" == "$OC_HOST" ]]
}

container_name() {
    local instance="$1"
    if [[ "$instance" == "default" ]]; then
        echo "openclaw"
    else
        echo "openclaw-${instance}"
    fi
}

# Shell-quote a string for safe embedding in bash -c or ssh arguments
shell_quote() {
    printf '%q' "$1"
}

# Build a properly quoted command string from arguments
quote_args() {
    local quoted=""
    local arg
    for arg in "$@"; do
        if [[ -n "$quoted" ]]; then
            quoted+=" "
        fi
        quoted+="$(shell_quote "$arg")"
    done
    echo "$quoted"
}

# Run a command as the service user.
# exec_as <needs_tty:yes|no> [command args...]
exec_as() {
    local needs_tty="$1"
    shift

    local quoted_cmd
    quoted_cmd="$(quote_args "$@")"
    local inner="XDG_RUNTIME_DIR=/run/user/${OC_UID} ${quoted_cmd}"

    if is_local; then
        exec sudo -u "${OC_USER}" -- bash -c "cd /tmp && ${inner}"
    else
        if [[ "$needs_tty" == "yes" ]]; then
            # -tt forces PTY allocation on both sides, critical for interactive
            # commands (configure, --shell) to propagate the terminal through
            # the full chain: ssh -> sudo -> bash -c -> podman exec -it
            exec ssh -tt -o ConnectTimeout=5 "${OC_HOST}" \
                "sudo -u ${OC_USER} -- bash -c $(shell_quote "cd /tmp && ${inner}")"
        else
            exec ssh -o ConnectTimeout=5 "${OC_HOST}" \
                "sudo -u ${OC_USER} -- bash -c $(shell_quote "cd /tmp && ${inner}")"
        fi
    fi
}

# --- Main ---
[[ $# -lt 1 ]] && usage

case "$1" in
    help|--help|-h)
        usage
        ;;
    list)
        exec_as "no" bash "${OC_HOME}/openclaw-instance.sh" list
        ;;
    *)
        instance="$1"
        shift
        [[ $# -lt 1 ]] && die "missing command. Usage: oc <instance> <command...>"

        cname="$(container_name "$instance")"
        needs_tty="no"

        case "$1" in
            --shell)
                needs_tty="yes"
                exec_as "$needs_tty" podman exec -it "${cname}" /bin/bash
                ;;
            --logs)
                shift
                lines="${1:-50}"
                exec_as "$needs_tty" podman logs --tail "${lines}" "${cname}"
                ;;
            *)
                # Detect interactive commands
                case "$1" in
                    configure|pairing|channels) needs_tty="yes" ;;
                esac

                # Build podman exec with appropriate flags
                if [[ "$needs_tty" == "yes" || ( -t 0 && -t 1 ) ]]; then
                    exec_as "$needs_tty" podman exec -it "${cname}" node dist/index.js "$@"
                else
                    exec_as "$needs_tty" podman exec "${cname}" node dist/index.js "$@"
                fi
                ;;
        esac
        ;;
esac
